{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentPlan",
  "description": "The structured plan an agent must lock through the Platform Planning Gateway before any execution tool will work.",
  "type": "object",
  "required": ["session_id", "intent", "repository_context", "steps"],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "stream_aligned_team": { "type": "string" },
    "intent": { "type": "string", "minLength": 5 },
    "skill_id": { "type": "string", "description": "Published skill driving this plan (Gate 3: the plan linter unions the skill's companion Rego; unknown ids reject the plan)" },
    "repository_context": {
      "type": "object",
      "required": ["name", "tech_stack"],
      "properties": {
        "name": { "type": "string" },
        "tech_stack": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "current_branch": { "type": "string" }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "action", "tool", "targets"],
        "properties": {
          "id": { "type": "string" },
          "action": { "type": "string" },
          "tool": { "type": "string" },
          "targets": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
