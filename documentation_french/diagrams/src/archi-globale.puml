@startuml archi-globale
!include octo-theme.puml

title Architecture globale — Platform Planning Gateway (PPG)\n<size:11>chaque brique porte une courte description de son rôle</size>

skinparam componentStyle rectangle

' ============ Projet cible (côté développeur) ============
package "Projet cible\n<size:10><i>le dépôt du développeur, celui que l'on gouverne</i></size>" as Projet #E8F0FE {
  folder ".agents/skills/ (Copilot)\n.claude/skills/ (Claude)\n<size:10><i>workflows installés via APM</i></size>" as Skills {
    [SKILL.md\n<size:10>workflow prose exécuté par l'agent</size>]
    [SKILL.rego\n<size:10>politique compagnon (Rego)</size>]
    [hooks/design-guard.sh\n<size:10>garde de contenu livrée par le skill</size>]
  }
  folder ".github/hooks/\n<size:10><i>déclarations locales des hooks PreToolUse</i></size>" as Hooks {
    [ppg.json\n<size:10>enregistre le garde de scope (ticket)</size>]
    [design.json\n<size:10>enregistre le garde de contenu (palette)</size>]
  }
  folder ".github/\n<size:10><i>contrat prose lu par l'agent au démarrage</i></size>" as Instr {
    [copilot-instructions.md\n<size:10>les invariants + les 3 règles du contrat</size>]
  }
  folder "racine du projet\n<size:10><i>fichiers d'état locaux, ignorés par git</i></size>" as Racine {
    [.ppg-ticket\n<size:10>JWT signé, écrit à chaque lock_in_plan</size>] as Ticket
    [.ppg-session\n<size:10>id de la session, écrite à SessionStart</size>] as Session
    [design/tokens.css\n<size:10>palette canonique (matérialisée par le skill)</size>] as Tokens
    [code applicatif\n<size:10>ce que l'agent est autorisé à modifier</size>]
  }
}

' ============ L'agent ============
node "Agent\n<size:10><i>GitHub Copilot ou Claude Code — modèle + boucle</i></size>" as Agent #DAF6F9 {
  [Chat / Boucle agentique\n<size:10>lit le contrat, appelle les tools</size>] as Loop
  [Client MCP\n<size:10>parle stdio à un serveur MCP local</size>] as MCPClient
  [Runtime des hooks\n<size:10>lance les scripts déclarés en .github/hooks/</size>] as HookRt
}

' ============ Adaptateurs (binaires locaux) ============
node "Adaptateurs (binaires locaux, sur PATH)\n<size:10><i>installés une fois par machine — tutoriel 0</i></size>" as Adapters #E6F4EA {
  [ppg-mcp-server\n<size:10>expose enrich + lock_in_plan comme tools MCP,</size>\n<size:10>relaie en HTTP à la gateway, écrit .ppg-ticket</size>] as MCPSrv
  [ppg-copilot-guard / ppg-guard\n<size:10>PreToolUse : lit .ppg-ticket, vérifie</size>\n<size:10>signature + TTL + session + scope, refuse hors-scope</size>] as PathGuard
  [design-guard.sh\n<size:10>PreToolUse livré dans le skill design-system,</size>\n<size:10>refuse toute couleur brute hors palette</size>] as ContentGuard
}

' ============ La passerelle PPG ============
node "Platform Planning Gateway\n<size:10><i>binaire ppg, service HTTP sur :8765 — le cerveau</i></size>" as PPG #FFEDB8 {
  [/enrich\n<size:10>répond aux ADR pertinents pour une intention</size>\n<size:10>(match par mots-clés → invariants prose)</size>] as Enrich
  [/lock_in_plan\n<size:10>évalue les policies Rego contre le plan,</size>\n<size:10>signe et retourne un JWT en cas de succès</size>] as Lock
  [/tools/{name}\n<size:10>tools sandboxés (patch_code, db-migration...) </size>\n<size:10>qui vérifient le ticket côté serveur</size>] as Tools
  [/validate_skill\n<size:10>gate de publication des skills</size>\n<size:10>(nom, description, tier, Rego compagnon)</size>] as Validate
  [/debt_report\n<size:10>ratio des artefacts amplifier vs compensatory,</size>\n<size:10>indicateur de dette de transition</size>] as Debt
}

' ============ Corpus (côté PPG) ============
database "Corpus ADR\n<size:10><i>adr/*.md (prose) + adr/*.rego (règles)</i></size>\n<size:10><i>chaque ADR a deux moitiés : humaine + exécutable</i></size>" as ADR #E8F0FE
database "Skill Governance\n<size:10><i>skill-governance/*.rego</i></size>\n<size:10><i>règles structurelles + sécurité pour la publication</i></size>" as SkillGov #E8F0FE

' ============ Liens ============
Loop --> Instr : lit\n(contrat)
Loop --> Skills : invoque un skill\n(/design-system ...)
Loop --> MCPClient : appelle un tool MCP
MCPClient --> MCPSrv : stdio
MCPSrv --> Enrich : POST /enrich
MCPSrv --> Lock : POST /lock_in_plan
Lock --> Ticket : écrit le JWT

Loop --> HookRt : Edit / Write déclenche PreToolUse
HookRt --> PathGuard : payload JSON
HookRt --> ContentGuard : payload JSON
PathGuard --> Ticket : lit .ppg-ticket
PathGuard --> Session : lit .ppg-session
ContentGuard --> Tokens : lit design/tokens.css

Enrich --> ADR : sélecteurs → invariants
Lock --> ADR : évaluation des policies
Validate --> SkillGov
Tools --> ADR : (analyseurs sémantiques)

note bottom of PPG #FFEDB8
  La gateway est un **service HTTP pur** : elle ne touche jamais
  au disque du projet. Toute la matérialisation locale
  (.ppg-ticket, hooks, tokens) est faite par les adaptateurs.
  Une même gateway peut ainsi servir plusieurs projets, machines
  ou organisations sans jamais avoir accès à leur code.
end note

note left of Adapters #E6F4EA
  Les adaptateurs sont installés une fois par machine
  (tutoriel 0). Ils sont écrits en Go (les gardes de scope)
  ou en shell (les gardes de contenu). Le contrat entre l'agent
  et un hook est trivial : JSON sur stdin, JSON sur stdout.
end note

@enduml
